# This .gitignore file should be placed at the root of your Unity project directory
# Get latest from https://github.com/github/gitignore/blob/main/Unity.gitignore

/[Ll]ibrary/
/[Tt]emp/
/[Oo]bj/
/[Bb]uild/
/[Bb]uilds/
/[Ll]ogs/
/[Uu]ser[Ss]ettings/

# MemoryCaptures can get excessive in size
/[Mm]emoryCaptures/

# Asset meta data should only be ignored when the corresponding asset is also ignored
!/[Aa]ssets/**/*.meta

# Uncomment this line if you want to ignore the AssetDatabase.asset file
# /[Pp]rojectSettings/AssetDatabase.config

# Uncomment this line if you wish to ignore the special "unitypackage" folder used to host Unity packages
# /[Uu]nityPackage/

# Autogenerated Jetbrains Rider plugin
/[Aa]ssets/Plugins/Editor/JetBrains*

# Visual Studio cache directory
.vs/

# Gradle cache directory
.gradle/

# gradle/wrapper/gradle-wrapper.properties
/gradle/wrapper/gradle-wrapper.properties

# Visual Studio Code
.vscode/

# Rider
.idea/

# Mac
.DS_Store

# Windows
Thumbs.db
*.tmp
*.log
*.swp
